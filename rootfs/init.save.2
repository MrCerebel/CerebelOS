#!/bin/sh

mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev

echo 3 > /proc/sys/kernel/printk
export PATH=/bin:/sbin:/usr/bin:/usr/sbin
hostname cerebelOS

# Load disk modules
/bin/busybox modprobe virtio_pci
/bin/busybox modprobe virtio_blk
/bin/busybox modprobe crc32c
/bin/busybox modprobe crc32c_generic
/bin/busybox modprobe ext4

# Mount real disk and switch root
/bin/busybox mount -t ext4 /dev/vda /mnt

# Networking
/bin/busybox modprobe e1000
/bin/busybox modprobe af_packet
/bin/busybox ifconfig eth0 up
/bin/busybox ip addr add 10.0.2.15/24 dev eth0
/bin/busybox ip route add default via 10.0.2.2 dev eth0
echo "nameserver 10.0.2.3" > /mnt/etc/resolv.conf

echo "If it works,don't touch it!"

